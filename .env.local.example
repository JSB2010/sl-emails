FIREBASE_PROJECT_ID=your-project-id
FIRESTORE_COLLECTION=emailWeeks
EMAILS_SESSION_SECRET=replace-with-a-local-secret
EMAILS_AUTOMATION_KEY=replace-with-a-local-automation-key
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_OAUTH_CALLBACK_URL=http://localhost:8080/auth/google/callback

# Pick one Firestore auth strategy:
# 1. Live Firestore through local ADC (preferred for the Docker runner).
# 2. Live Firestore through an inline service account JSON payload.
# 3. Emulator only.
#
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# FIRESTORE_EMULATOR_HOST=host.docker.internal:8080
